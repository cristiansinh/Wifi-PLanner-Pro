# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.spec
*.egg
*.pyc
*.pyo

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
Thumbs.db
Desktop.ini
.DS_Store

# Project backups and temp files
*_backup.*
*.bak
*.zip

# Claude Code
.claude/

# Compiled executables
*.exe

# ── Seguridad ────────────────────────────────────────────
# Archivos de entorno y secretos (NUNCA subir al repo)
.env
.env.*
*.env
.env.local
.env.production
.env.development

# Archivos de configuración con posibles credenciales
secrets.json
secrets.yaml
secrets.yml
credentials.json
config.local.json

# Logs de la aplicación
*.log
logs/

# Archivos de configuración generados en runtime
# (WiFiPlannerPro los guarda en %LOCALAPPDATA%, no aquí,
#  pero se ignoran por precaución)
config.json

# Artefactos numéricos (e.g. archivos "4.0.0" creados por pip)
[0-9]*.[0-9]*.[0-9]*
